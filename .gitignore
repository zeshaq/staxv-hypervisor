# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# staxv-hypervisor specific
# Anchor to repo root so this matches only the built binary, not
# paths like cmd/staxv-hypervisor/ or api/staxv-hypervisor/.
/staxv-hypervisor
/staxv-hypervisor.exe
config.toml
secrets.json
secrets.json.tmp
*.db
*.db-shm
*.db-wal
frontend/node_modules/
frontend/dist/
static/
.env

# Claude memory — secrets only. All other memory files ARE committed
# so the repo is self-describing to future sessions and collaborators.
.claude/memory/servers.md

# Dev-loop artifacts
/tmp/
dev-config.toml
build-errors.log

# Frontend build artifacts (rebuilt by `make frontend`)
frontend/node_modules/
frontend/dist/
internal/webui/dist/*
!internal/webui/dist/.gitkeep
