# Copy to dev-config.toml (gitignored) and tweak for your box.
# Dev run: make dev   (air uses ./dev-config.toml via .air.toml args_bin)
# Prod/staging run: /etc/staxv-hypervisor/config.toml.

[server]
addr = ":5001"      # coexists with vm-manager on :5000
secure = false      # set true when serving behind TLS (cookie Secure flag)

[log]
level = "debug"     # debug | info | warn | error

[db]
path = "./tmp/staxv.db"

[auth]
# How passwords are verified:
#   "db"  — bcrypt hash in the users table (default, self-contained)
#   "pam" — shell out to pamtester against the host's PAM stack;
#          users log in with their Linux password. Requires:
#            apt install pamtester
#            /etc/pam.d/staxv-hypervisor configured (see memory/multi_tenancy.md)
#          Users must be linked first:
#            staxv-hypervisor useradd --username <name> --link-existing
backend = "db"
pam_service = "staxv-hypervisor"  # /etc/pam.d/<this name> when backend="pam"
secret_path = "./tmp/jwt.key"     # 32-byte HS256 secret; generated on first run
ttl = "24h"                       # session lifetime

[secrets]
# 32-byte AES-256 key used to encrypt /api/settings values at rest.
# Auto-generated on first run. Back this up in prod — losing it makes
# encrypted settings unreadable.
key_path = "./tmp/settings.key"

[host]
# Ubuntu defaults — override only if libvirt runs as different user (RHEL etc.)
qemu_user  = "libvirt-qemu"
qemu_group = "kvm"

[libvirt]
# Local qemu:///system via the standard Ubuntu socket. For remote libvirt
# (tcp+tls://), support pending — we'd need TLS client cert setup.
uri = "unix:///var/run/libvirt/libvirt-sock"

[isos]
# Shared ISO library — admin-uploaded files, readable by everyone for
# VM creation. Created on first run (0755). Per-user libraries will
# be added with #33 provisioning.
shared_path = "/var/lib/staxv/shared/isos"
